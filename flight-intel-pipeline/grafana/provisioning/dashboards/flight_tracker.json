          "queryType": "sql",
          "rawSql": "SELECT\n  Icao24,\n  argMax(Callsign, IngestedAt) as callsign,\n  argMax(OriginCountry, IngestedAt) as country,\n  argMax(Longitude, IngestedAt) as lon,\n  argMax(Latitude, IngestedAt) as lat,\n  argMax(Velocity, IngestedAt) as speed\nFROM flights\nWHERE $__timeFilter(IngestedAt)\n  AND Longitude IS NOT NULL\nGROUP BY Icao24",
